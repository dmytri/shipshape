{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipshape.dev/schemas/cycle.json",
  "title": "Shipshape cycle.json schema",
  "description": "Optional QM worklist. Only ordered passes of scenario references — no freeform text. QM validates against this schema and refuses if invalid.",
  "type": "object",
  "patternProperties": {
    "^pass[1-9][0-9]*$": {
      "type": "object",
      "properties": {
        "scenarios": {
          "type": "array",
          "description": "Scenario refs in 'features/file.feature:Scenario Name' format",
          "items": {
            "type": "string",
            "pattern": "^.+\\.feature:.+$"
          },
          "minItems": 1
        }
      },
      "required": ["scenarios"],
      "additionalProperties": false
    }
  },
  "required": ["pass1"],
  "additionalProperties": false
}
